{
  "name": "one-personal-site",
  "private": true,
  "scripts": {
    "dev": "./dev-start.sh",
    "dev:stop": "./dev-stop.sh",
    "check:backend": "npm --prefix lxhcool-backend run build",
    "check:frontend": "npm --prefix lxhcool-frontend run typecheck",
